#!/bin/bash
{{/*
  run_once_after_20-install-chrome-extensions.sh.tmpl

  Runs once after chezmoi apply on a NEW machine. Reads chrome/extensions.json
  from the repo and writes in External Extensions
  so Chrome silently installs each extension from the Web Store on next launch.
  No Google Sync / no sign-in required.
  Requires and jq.
*/ -}}
set -euo pipefail

{{ if .isCI -}}
echo "CI environment detected - skipping interactive Chrome extension force-install step."
exit 0
{{ end -}}

EXTENSIONS_SRC="{{ .chezmoi.sourceDir }}/.chrome-data/extensions.json"
EXTENSIONS_FOLDER="$HOME/Library/Application Support/Google/Chrome/External Extensions/"

if [ ! -f "$EXTENSIONS_SRC" ]; then
  echo "chrome/extensions.json not found in dotfiles repo - skipping extension install."
  exit 0
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "jq is required for this step but was not found."
  echo "Install it first (e.g. via your Brewfile) and re-run:"
  echo "  chezmoi state delete-bucket --bucket=scriptState"
  echo "  chezmoi apply"
  exit 1
fi

mkdir -p "$EXTENSIONS_FOLDER"

ids=$(jq -r '.[].id' "$EXTENSIONS_SRC")
count=0
while IFS= read -r id; do
  [ -z "$id" ] && continue
  echo "{
    \"external_update_url\": \"https://clients2.google.com/service/update2/crx\"
  }" > "$EXTENSIONS_FOLDER/$id.json"
  count=$((count + 1))
done <<< "$ids"

echo "Wrote json files for $count extension(s)."
echo "Restart Chrome (fully quit, not just close windows) for it to apply."