#!/bin/bash
{{ if eq .chezmoi.os "darwin" -}}


# Generate combined Brewfile in a temp file
brewfile=$(mktemp)
cat > "$brewfile" <<BREWEOF
{{ range .packages.universal.taps -}}
tap {{ . | quote | replace " " "\", \"" }}
{{ end -}}
{{ range .packages.universal.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.universal.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ if not .isCI -}}
{{ range .packages.universal.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}
{{ end -}}
{{ range .packages.universal.vscode -}}
vscode {{ . | quote }}
{{ end -}}
{{ if .isWorkComputer -}}
{{ range .packages.work.taps -}}
tap {{ . | quote | replace " " "\", \"" }}
{{ end -}}
{{ range .packages.work.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.work.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ if not .isCI -}}
{{ range .packages.work.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}
{{ end -}}
{{ range .packages.work.vscode -}}
vscode {{ . | quote }}
{{ end -}}
{{ else -}}
{{ range .packages.private.taps -}}
tap {{ . | quote | replace " " "\", \"" }}
{{ end -}}
{{ range .packages.private.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.private.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ if not .isCI -}}
{{ range .packages.private.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}
{{ end -}}
{{ range .packages.private.vscode -}}
vscode {{ . | quote }}
{{ end -}}
{{ end -}}
BREWEOF

brew bundle --file="$brewfile"

# Warn about and remove undeclared packages
undeclared=$(brew bundle cleanup --file="$brewfile" 2>/dev/null)
if [[ -n "$undeclared" ]]; then
    echo ""
    echo "WARNING: Removing packages not declared in packages.yaml:"
    echo "$undeclared"
    brew bundle cleanup --force --file="$brewfile"
    brew autoremove
fi

{{ range .packages.universal.npm -}}
npm install -g {{ . | quote }}
{{ end -}}
{{ if .isWorkComputer -}}
{{ range .packages.work.npm -}}
npm install -g {{ . | quote }}
{{ end -}}
{{ else -}}
{{ range .packages.private.npm -}}
npm install -g {{ . | quote }}
{{ end -}}
{{ end -}}

mise trust $HOME/.config/mise/config.toml && mise install --verbose

sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"

# Enable colima to auto-start at login
brew services restart colima

# Skyline cli
{{ if .isWorkComputer -}}

curlResponse="$(curl -L -s -w %{http_code} -o /tmp/response.txt https://git.corp.adobe.com/)"

if [ "$curlResponse" = "200" ]; then
brew tap experience-platform/homebrew-internal git@git.corp.adobe.com:experience-platform/homebrew-internal.git
brew install skyline-ops-cli
else
echo "You are not connected to the corporate VPN to complete installation of skyline-cli"
echo "Run yourself brew tap experience-platform/homebrew-internal git@git.corp.adobe.com:experience-platform/homebrew-internal.git && brew install skyline-ops-cli  after you have connected to VPN"
fi

{{ end -}}

{{ end -}}